; --- symbol case insensitivity ---

>>> ;;; uppercase NIL is the same symbol as lowercase nil
... NIL
...

==> NIL

>>> ;;; lowercase t self-evaluates to T
... t
...

==> T

>>> ;;; quoted symbols are case-folded: 'pi and 'PI name the same symbol
... (is? 'pi 'PI)
...

==> T

>>> ;;; extreme mixed case also folds identically
... (is? 'Hello 'hElLo)
...

==> T

>>> ;;; strings are NOT case-folded — contrast with symbols
... (is? "abc" "ABC")
...

==> NIL

