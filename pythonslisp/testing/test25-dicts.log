; ============================================================
; dict-length
; ============================================================

; 3-entry dict
>>> (dict-length d1)

==> 3

; empty dict
>>> (dict-length (make-dict))

==> 0

; 1-entry dict
>>> (dict-length (make-dict (x 42)))

==> 1

; error cases: dict-length

; error: argument is a list
>>> (dict-length '(1 2 3))

%%% ERROR 'DICT-LENGTH': Argument 1 must be a Dict.
%%% PRIMITIVE USAGE: (DICT-LENGTH dict)
==>

; error: argument is NIL
