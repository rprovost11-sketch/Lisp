... (copy-tree "hello")

==> "hello"

>>> ;;; copy-tree independence: mutating original does not affect copy
... (let ((orig23 (list 1 (list 2 3) 4))
...       (cp23 (copy-tree (list 1 (list 2 3) 4))))
...    (setf (at 0 (at 1 orig23)) 99)
...    (at 1 cp23))

==> (2 3)

