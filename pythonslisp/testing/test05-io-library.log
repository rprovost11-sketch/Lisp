; ============================================================
; String escape sequences
; ============================================================

; --- User mode: escape sequences converted to actual characters ---

>>> ;;; \n outputs an actual newline
... (uwrite! "\n")

==> "\n"

>>> ;;; \t outputs an actual tab
... (uwrite! "\t")

==> "\t"

>>> ;;; \x hex escape outputs the corresponding character
... (uwrite! "\x41\x42\x43")
ABC
==> "ABC"

>>> ;;; programmer mode preserves \n as escape notation
... (write! "\n")
"\n"
==> "\n"

>>> ;;; programmer mode preserves \t as escape notation
... (write! "\t")
"\t"
==> "\t"

>>> ;;; programmer mode shows \x41 as the actual character A
... (write! "\x41")
"A"
==> "A"

>>> ;;; writef with \n escape in format string
... (writef "line1\nline2\n")
line1
line2

==> "line1\nline2\n"

