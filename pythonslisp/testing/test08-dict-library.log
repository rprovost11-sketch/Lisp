; --------------------------------------------------------
; make-dict, at, has-value-p, has-key-p, update!
; --------------------------------------------------------

>>> (setf mymap (make-dict ("a" 1) ("b" 2) ("c" 3) ) )
...

==> (DICT
   ("a" 1)
   ("b" 2)
   ("c" 3)
)

>>> mymap
...

==> (DICT
   ("a" 1)
   ("b" 2)
   ("c" 3)
)

>>> (at "b" mymap)
...

==> 2

>>> (setf (at "b" mymap) e)
...

==> 2.718281828459045

>>> mymap
...

==> (DICT
   ("a" 1)
   ("b" 2.718281828459045)
   ("c" 3)
)

>>> (has-value-p 1 mymap)
...

==> T

>>> (has-value-p 10 mymap)
...

==> NIL

>>> (update! mymap (make-dict ("b" 5) ("d" 10)))
...

==> (DICT
   ("a" 1)
   ("b" 5)
   ("c" 3)
   ("d" 10)
)

>>> mymap
...

==> (DICT
   ("a" 1)
   ("b" 5)
   ("c" 3)
   ("d" 10)
)

>>> (has-key-p "a" mymap)
...

==> T

>>> (has-key-p 3 mymap)
...

==> NIL

; --------------------------------------------------------
; at with symbol key on dict; has-value-p on dict
; has-key-p on empty dict; at with integer keys
; --------------------------------------------------------

>>> ;;; at with symbol key on map
... (at 'a (make-dict (a 1) (b 2)))
...

==> 1

>>> ;;; has-value-p on map (true)
... (has-value-p 2 (make-dict (a 1) (b 2)))
...

==> T

>>> ;;; has-value-p on map (false)
... (has-value-p 3 (make-dict (a 1) (b 2)))
...

==> NIL

>>> ;;; has-key-p on empty map
... (has-key-p 'a (make-dict))
...

==> NIL

>>> ;;; map with integer keys
... (at 1 (make-dict (1 "a") (2 "b")))
...

==> "a"

; --------------------------------------------------------
; at-delete on dict
; --------------------------------------------------------

>>> (setf tmap (make-dict (a 10) (b 20) (c 30)))
...

==> (DICT
   (A 10)
   (B 20)
   (C 30)
)

>>> (at-delete 'a tmap)
...

==> T

>>> tmap
...

==> (DICT
   (B 20)
   (C 30)
)

; --------------------------------------------------------
; at-set on dict — symbol and string keys
; --------------------------------------------------------

>>> (setf skmap (make-dict (x 10) (y 20)))
...

==> (DICT
   (X 10)
   (Y 20)
)

>>> ;;; quoted symbol key is uppercased to match the stored key
... (at-set 'x skmap 99)
...

==> 99

>>> skmap
...

==> (DICT
   (X 99)
   (Y 20)
)

>>> ;;; at-set adds a new key when the key is not already present
... (at-set 'z skmap 30)
...

==> 30

>>> skmap
...

==> (DICT
   (X 99)
   (Y 20)
   (Z 30)
)

>>> (setf strmap (make-dict ("p" 1) ("q" 2)))
...

==> (DICT
   ("p" 1)
   ("q" 2)
)

>>> (at-set "p" strmap 88)
...

==> 88

>>> strmap
...

==> (DICT
   ("p" 88)
   ("q" 2)
)

; --------------------------------------------------------
; setf with at on dict
; --------------------------------------------------------

>>> (setf smap22 (make-dict (a 1) (b 2)))
...

==> (DICT
   (A 1)
   (B 2)
)

>>> ;;; setf at on map mutates the value
... (setf (at 'a smap22) 99)
...

==> 99

>>> smap22
...

==> (DICT
   (A 99)
   (B 2)
)

; --------------------------------------------------------
; make-dict edge cases
; --------------------------------------------------------

>>> ;;; empty dict
... (make-dict)

==> (DICT
)

>>> ;;; empty dict is a dict
... (dictp (make-dict))

==> T

>>> ;;; dict values are evaluated
... (make-dict (a (+ 1 2)))

==> (DICT
   (A 3)
)

>>> ;;; at retrieves evaluated dict value
... (at 'a (make-dict (a (+ 1 2))))

==> 3

>>> ;;; dict with duplicate keys (last wins)
... (make-dict (a 1) (a 2))

==> (DICT
   (A 2)
)

>>> ;;; dict with integer keys
... (make-dict (1 "one") (2 "two"))

==> (DICT
   (1 "one")
   (2 "two")
)

>>> ;;; at with integer key on integer-keyed dict
... (at 1 (make-dict (1 "one") (2 "two")))

==> "one"

; --------------------------------------------------------
; dictp predicate
; --------------------------------------------------------

>>> ;;; empty dict
... (dictp (make-dict))
...

==> T

