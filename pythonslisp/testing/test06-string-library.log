%%% Runtime Error: "" (2,2)
%%% (at 0 "")
%%%  ^
%%% ERROR 'AT': Invalid argument 1. Key/index out of range or wrong type.
%%% PRIMITIVE USAGE: (AT keyOrIndex dictListOrStr)
==>

; ============================================================
; String escape sequences — actual-character storage model
; ============================================================

>>> ;;; \n is 1 character (actual newline), not 2
... (length "\n")

==> 1

>>> ;;; \t is 1 character (actual tab)
... (length "\t")

==> 1

>>> ;;; \x41 is 1 character (letter A)
... (length "\x41")

==> 1

>>> ;;; escape sequence resolves to correct character
... (= (at 0 "\x41") "A")

==> T

>>> ;;; \n resolves to char-code 10
... (char-code (at 0 "\n"))

==> 10

