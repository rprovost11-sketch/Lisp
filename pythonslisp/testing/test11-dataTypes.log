; --- typecase ---

>>> (typecase 42
...   (string "str")
...   (integer "int")
...   (otherwise "other"))
==> "int"

>>> (typecase "hi"
...   (integer "int")
...   (string "str"))
==> "str"

>>> (typecase nil
...   (integer "int")
...   (null "null"))
==> "null"

; no matching clause returns nil
>>> (typecase 3.14
...   (integer "int")
...   (string "str"))
==> NIL

; t as catch-all
>>> (typecase 'foo
...   (integer "int")
...   (t "other"))
==> "other"

