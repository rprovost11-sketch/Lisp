   (STRUCT-TYPE POINT)
   (X 10)
   (Y 99)
)

>>> (setf (point-x p1) 0)
...

==> 0

>>> (point-x p1)
...

==> 0

>>> (point-x p2)
...

==> 10

>>> (setf (point-y p2) 1000)
...

==> 1000

>>> (point-y p2)
...

==> 1000

>>> (point-y p1)
...

==> 99

