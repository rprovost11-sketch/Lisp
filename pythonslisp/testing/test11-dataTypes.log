>>> (string-stream-p (make-string-output-stream))
==> T

>>> (file-stream-p (make-string-output-stream))
==> NIL

>>> (string-stream-p (make-string-input-stream "hi"))
==> T

>>> (string-stream-p 42)
==> NIL

>>> (file-stream-p 42)
==> NIL

