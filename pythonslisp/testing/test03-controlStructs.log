>>> ;;; restart-case normal completion returns body value
... (restart-case (+ 10 20) (fix () 0))
==> 30

>>> ;;; invoke-restart transfers to matching restart clause
... (restart-case (invoke-restart 'use-value 42) (use-value (v) v))
==> 42

>>> ;;; restart clause with no params
... (restart-case (invoke-restart 'skip) (skip () 'skipped))
==> SKIPPED

>>> ;;; handler-bind + restart-case with error
... (handler-bind ((error (lambda (c) (invoke-restart 'recover))))
...   (restart-case (error "boom")
...     (recover () 99)))
==> 99

>>> ;;; handler-bind + restart-case with signal
... (handler-bind ((my-err (lambda (c) (invoke-restart 'use-val (condition-message c)))))
...   (restart-case (signal 'my-err "hello")
...     (use-val (v) (list 'got v))))
==> (GOT "hello")

