; --- Control structure errors ---

>>> (while)

%%% Too few positional arguments.
==>

>>> ;;; while with no body
... (while t)

%%% while: at least one body expression is required
==>

>>> (dotimes)

%%% Too few positional arguments.
==>

>>> ;;; dotimes control list must be a list
... (dotimes i 1)

%%% Destructuring pattern expects a list argument, got LSymbol.
==>

>>> ;;; dotimes control list must have at most 3 elements
... (dotimes (i 3 4 5) 1)

%%% Too many arguments.  Received 4.
==>

>>> ;;; dotimes variable must be a symbol
... (dotimes (1 3) 1)

%%% dotimes: loop variable must be a symbol
==>

>>> ;;; dotimes count must be integer
... (dotimes (i "a") 1)

%%% dotimes: count must be an integer
==>

>>> (dolist)

%%% Too few positional arguments.
==>

>>> ;;; dolist with bad control spec
... (dolist x (write! x))

%%% Destructuring pattern expects a list argument, got LSymbol.
==>

>>> ;;; dolist variable must be a symbol
... (dolist (1 '(a b)) (write! 1))

%%% dolist: control spec variable must be a symbol
==>

>>> ;;; dolist list must evaluate to a list
... (dolist (x 42) (write! x))

%%% dolist: list must evaluate to a list
==>

>>> ;;; while returns last body value
... (let ((n 1))
...    (while (> n 0)
...       (setf n (- n 1))
...       42))
...

==> 42

>>> (when t 42)
...

==> 42

>>> (when nil 42)
...

==> NIL

>>> (unless nil 42)
...

==> 42

>>> (unless t 42)
...

==> NIL

; --- when/unless with multiple body forms ---

>>> ;;; when true with multiple body forms returns last
... (when t 1 2)
...

==> 2

>>> ;;; when false with multiple body forms returns NIL
... (when nil 1 2)
...

==> NIL

>>> ;;; unless false with multiple body forms returns last
... (unless nil 1 2)
...

==> 2

>>> ;;; unless true with multiple body forms returns NIL
... (unless t 1 2)
...

==> NIL

; --- dotimes with negative count ---

>>> ;;; dotimes with negative count does zero iterations
... (dotimes (i -1) (write! i))

==> NIL

; --- DOLIST additional error path ---

>>> ;;; dolist with no body expressions is allowed (returns NIL)
... (dolist (x '(1 2)))
...

==> NIL
