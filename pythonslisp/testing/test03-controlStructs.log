>>> (defun countdown1 (num)
...    (while (> num 0)
...       (let ()
...          (write-line num)
...          (setf num (- num 1))
...          )
...       )
...    )
...

==> (FUNCTION COUNTDOWN1 (NUM) ...)

>>> (countdown1 5)
...
5
4
3
2
1

==> 0

