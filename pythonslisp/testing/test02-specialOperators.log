; test02-specialOperators.log
; Tests for special operators (excluding lambda and defmacro,
; which have their own test files).
; Covered: QUOTE, IF, PROGN, COND, CASE, LET, LET*, SETQ,
;   FUNCALL, APPLY, QUASIQUOTE, BLOCK, RETURN-FROM, CATCH/THROW,
;   HANDLER-CASE, MULTIPLE-VALUE-BIND, NTH-VALUE,
;   MULTIPLE-VALUE-LIST, MAKE-DICT, : (module access),
;   CALL/CC, DYNAMIC-WIND
; ============================================================

; ============================================================
; QUOTE
; ============================================================

; symbol
>>> (quote x)
==> X

; list
>>> (quote (1 2 3))
==> (1 2 3)

; nil
>>> (quote nil)
==> NIL

; reader shorthand: single symbol
>>> 'x
==> X

; reader shorthand: list
>>> '(a b c)
==> (A B C)

>>> (quote)

%%% Runtime Error: "" (1,2)
%%% (quote)
%%%  ^
%%% ERROR 'QUOTE': 1 argument expected.
%%% PRIMITIVE USAGE: (QUOTE sexpr)
==>

>>> (quote 1 2)

%%% Runtime Error: "" (1,2)
%%% (quote 1 2)
%%%  ^
%%% ERROR 'QUOTE': 1 argument expected.
%%% PRIMITIVE USAGE: (QUOTE sexpr)
==>

; ============================================================
; IF
; ============================================================

; two-branch true
>>> (if t 'yes 'no)
==> YES

; two-branch false
>>> (if nil 'yes 'no)
==> NO

>>> (if nil 42)
...

==> NIL

>>> (if nil 42 99)
...

==> 99

>>> (if t 1)
...

==> 1

; ============================================================
; PROGN
; ============================================================

; empty progn returns NIL
>>> (progn)
==> NIL

>>> (progn 1 2 3)
...

==> 3

>>> (let ((n 5)) (progn (setf n (* n n)) n))
...

==> 25

; ============================================================
; COND
; ============================================================

; no matching clause returns NIL
>>> (cond ((= 1 99) 'nope))
==> NIL

; t clause as default
>>> (cond ((= 1 99) 'nope) (t 'default))
==> DEFAULT

>>> (setf val1 3)
...

==> 3

>>> (cond
...    ((= val1 1)
...                 "one")
...    ((= val1 2)
...                 "two")
...    ((= val1 3)
...                 "three"))
...

==> "three"

>>> ;;; Error: cond requires at least one clause
... (cond)

%%% Runtime Error: "" (2,2)
%%% (cond)
%%%  ^
%%% ERROR 'COND': 1 or more arguments expected.
%%% PRIMITIVE USAGE: (COND (cond1 body1) (cond2 body2) ...)
==>

; ============================================================
; CASE
; ============================================================

>>> (case val1
...    (1
...        "one")
...    (2
...        "two")
...    (3
...        "three")
...    )
...

==> "three"

; case: list of keys — matches first key in group
>>> (case 1
...    ((1 2 3) "low")
...    ((4 5 6) "high")
...    (t       "other"))
...

==> "low"

; case: list of keys — matches second key in group
>>> (case 5
...    ((1 2 3) "low")
...    ((4 5 6) "high")
...    (t       "other"))
...

==> "high"

; case: list of keys — falls through to t
>>> (case 9
...    ((1 2 3) "low")
...    ((4 5 6) "high")
...    (t       "other"))
...

==> "other"

; case: list of symbol keys
>>> (case 'b
...    ((a b)   "ab")
...    ((c d)   "cd")
...    (otherwise "other"))
...

==> "ab"

; case: list of symbol keys — no match, otherwise clause
>>> (case 'z
...    ((a b)   "ab")
...    ((c d)   "cd")
...    (otherwise "other"))
...

==> "other"

>>> (case)

%%% Runtime Error: "" (1,2)
%%% (case)
%%%  ^
%%% ERROR 'CASE': 2 or more arguments expected.
%%% PRIMITIVE USAGE: (CASE sexpr (val1 body1) (val2 body2) ...)
==>

; ============================================================
; LET
; ============================================================

; uninitialized var defaults to NIL
>>> (let ((x)) x)
==> NIL

; empty binding list
>>> (let () 42)
==> 42

; parallel binding: y sees outer x (10), not inner x (1)
>>> (let ((x 10))
...    (let ((x 1) (y x))
...       y))
==> 10

; scoping: inner let shadows outer x
>>> (let ((x 1))
...    (let ((y (+ x 1)))
...       (+ x y)))
==> 3

; --- let / let* errors ---

>>> (let)

%%% Runtime Error: "" (1,2)
%%% (let)
%%%  ^
%%% ERROR 'LET': 2 or more arguments expected.
%%% PRIMITIVE USAGE: (LET ( (var1 sexpr1) (var2 sexpr2) ...) &rest body)
==>

>>> ;;; let first arg must be list
... (let 1 2)

%%% Runtime Error: "" (2,2)
%%% (let 1 2)
%%%  ^
%%% ERROR 'LET': Invalid argument 1. LIST OF VARIABLE BINDINGS expected.
%%% PRIMITIVE USAGE: (LET ( (var1 sexpr1) (var2 sexpr2) ...) &rest body)
==>

>>> ;;; let var spec first element must be symbol
... (let ((1 2)) 1)

%%% Runtime Error: "" (2,2)
%%% (let ((1 2)) 1)
%%%  ^
%%% ERROR 'LET': Variable binding name expected to be a SYMBOL.
%%% PRIMITIVE USAGE: (LET ( (var1 sexpr1) (var2 sexpr2) ...) &rest body)
==>

>>> ;;; let var spec must be 1 or 2 elements
... (let ((x 1 2)) 1)

%%% Runtime Error: "" (2,2)
%%% (let ((x 1 2)) 1)
%%%  ^
%%% ERROR 'LET': Variable initializer spec expected to be 1 or 2 elements long.
%%% PRIMITIVE USAGE: (LET ( (var1 sexpr1) (var2 sexpr2) ...) &rest body)
==>

; ============================================================
; LET*
; ============================================================

; empty binding list
>>> (let* () 42)
==> 42

>>> (let* ((a 2) (b (* a 3))) b)
...

==> 6

>>> (let* ((x 10) (y (+ x 5))) y)
...

==> 15

>>> (let*)

%%% Runtime Error: "" (1,2)
%%% (let*)
%%%  ^
%%% ERROR 'LET*': 2 or more arguments expected.
%%% PRIMITIVE USAGE: (LET* ( (var1 sexpr1) (var2 sexpr2) ...) &rest body)
==>

>>> ;;; let* first arg must be list
... (let* 1 2)

%%% Runtime Error: "" (2,2)
%%% (let* 1 2)
%%%  ^
%%% ERROR 'LET*': Invalid argument 1. LIST OF VARIABLE BINDINGS expected.
%%% PRIMITIVE USAGE: (LET* ( (var1 sexpr1) (var2 sexpr2) ...) &rest body)

; ============================================================
; SETQ
; ============================================================

; --- 1. setq: basic assignment ---

>>> (setq sq1 99)
...

==> 99

>>> sq1
...

==> 99

>>> (setq sq1 100)
...

==> 100

>>> sq1
...

==> 100

>>> (setq sq2 3.14)
...

==> 3.14

>>> (setq sq3 "hello")
...

==> "hello"

>>> (setq sq4 '(a b c))
...

==> (A B C)

>>> (setq sq5 nil)
...

==> NIL

>>> (setq sq6 t)
...

==> T

; --- 2. setq: multiple pairs in one call ---

>>> ;;; returns the value of the last assignment
... (setq ma 1 mb 2 mc 3)
...

==> 3

>>> ma
...

==> 1

>>> mb
...

==> 2

>>> mc
...

==> 3

; --- 3. setq: scope behaviour ---

>>> ;;; setq inside let finds and updates the let-local binding
... (let ((lvar 5))
...    (setq lvar 99)
...    lvar)
...

==> 99

>>> ;;; the let-local did not leak into the global scope
... (boundp 'lvar)
...

==> NIL

>>> ;;; setq creates a new global when the name is not bound anywhere
... (setq sq-new 777)
...

==> 777

>>> sq-new
...

==> 777

; --- 4. setq: auto-names a lambda ---

>>> (setq sq-fn (lambda (x) (* x x)))
...

==> (FUNCTION SQ-FN (X) ...)

>>> (sq-fn 7)
...

==> 49

; --- 5. setq: error cases ---

>>> ;;; no arguments
... (setq)

%%% Runtime Error: "" (2,2)
%%% (setq)
%%%  ^
%%% ERROR 'SETQ': At least 2 arguments expected.
%%% PRIMITIVE USAGE: (SETQ symbol1 sexpr1 symbol2 sexpr2 ...)
==>

>>> ;;; odd number of arguments
... (setq sq1 1 sq2)

%%% Runtime Error: "" (2,2)
%%% (setq sq1 1 sq2)
%%%  ^
%%% ERROR 'SETQ': An even number of arguments is expected.  Received 3.
%%% PRIMITIVE USAGE: (SETQ symbol1 sexpr1 symbol2 sexpr2 ...)
==>

>>> ;;; non-symbol lvalue
... (setq 42 1)

%%% Runtime Error: "" (2,2)
%%% (setq 42 1)
%%%  ^
%%% ERROR 'SETQ': First of setf pair must be a symbol.
%%% PRIMITIVE USAGE: (SETQ symbol1 sexpr1 symbol2 sexpr2 ...)
==>

; ============================================================
; FUNCALL
; ============================================================

; call a primitive directly
>>> (funcall car '(1 2 3))
==> 1

; call a lambda
>>> (funcall (lambda (x) (* x x)) 5)
==> 25

; call a two-argument lambda
>>> (funcall (lambda (x y) (+ x y)) 3 4)
==> 7

; call a primitive by value
>>> (funcall reverse '(a b c))
==> (C B A)

; ============================================================
; APPLY
; ============================================================

; basic apply with final list
>>> (apply + '(1 2 3))
==> 6

; leading args before the final list
>>> (apply + 1 2 '(3 4))
==> 10

; apply with a lambda
>>> (apply (lambda (x y) (+ x y)) '(3 4))
==> 7

; leading scalars merged into final list
>>> (apply list 1 2 '(3 4))
==> (1 2 3 4)

; empty final list
>>> (apply + '())
==> 0

; ============================================================
; QUASIQUOTE
; ============================================================

>>> (setf name 'john)
...

==> JOHN

>>> `(go ,name go)
...

==> (GO JOHN GO)

>>> `( name ,name age ,(+ 3 7))
...

==> (NAME JOHN AGE 10)

>>> `,name
...

==> JOHN

>>> (setf full '(r h l))
...

==> (R H L)

>>> `( ,@full )
...

==> (R H L)

; --- nested quasiquotes ---

>>> ;;; inner quasiquote preserved as data no unquotes
... `(a `b)
...

==> (A (QUASIQUOTE B))

>>> ;;; inner unquote preserved as form (belongs to inner quasiquote)
... `(a `(b ,name))
...

==> (A (QUASIQUOTE (B (UNQUOTE NAME))))

>>> ;;; double-unquote: outer unquote evaluated now, inner unquote preserved
... `(a `(b ,,name))
...

==> (A (QUASIQUOTE (B (UNQUOTE JOHN))))

>>> ;;; unquote outside quasiquote
... ,x

%%% ERROR 'UNQUOTE': UNQUOTE can only occur inside a QUASIQUOTE.
%%% PRIMITIVE USAGE: (UNQUOTE sexpr)
==>

>>> ;;; unquote-splicing outside quasiquote
... ,@x

%%% ERROR 'UNQUOTE-SPLICING': UNQUOTE-SPLICING can only occur inside a QUASIQUOTE.
%%% PRIMITIVE USAGE: (UNQUOTE-SPLICING sexpr)
==>

; ============================================================
; BLOCK / RETURN-FROM
; ============================================================

; --- block and return-from ---

; block returns value of last body form
>>> (block myblock 1 2 3)
==> 3

; block with no body returns NIL
>>> (block myblock)
==> NIL

; return-from exits the block immediately, skipping remaining forms
>>> (block myblock
...    (return-from myblock 42)
...    99)
==> 42

; return-from with no value returns NIL
>>> (block myblock
...    (return-from myblock)
...    99)
==> NIL

; return-from from inside a nested expression
>>> (+ 1 (block escape
...         (+ 10 (return-from escape 5))))
==> 6

; nested blocks with same name innermost is exited
>>> (block foo
...    (block foo
...       (return-from foo 1))
...    2)
==> 2

; return-from to outer block bypasses the inner block entirely
>>> (block outer
...    (block inner
...       (return-from outer 99))
...    42)
==> 99

; block used as early-exit in a search loop
>>> (defun find-even (lst)
...    (block found
...       (dolist (x lst)
...          (if (evenp x) (return-from found x)))
...       nil))
==> (FUNCTION FIND-EVEN (LST) ...)

>>> (find-even '(1 3 5 4 7))
==> 4

>>> (find-even '(1 3 5 7))
==> NIL

; --- block nil and return ---

; (block nil ...) acts like a named block
>>> (block nil 1 2 3)
==> 3

; (return value) exits (block nil ...)
>>> (block nil
...    (return 42)
...    99)
==> 42

; (return) with no value returns NIL
>>> (block nil
...    (return)
...    99)
==> NIL

; dotimes with early (return ...)
>>> (let ((sum 0))
...    (dotimes (i 10)
...       (if (= i 5) (return sum))
...       (setf sum (+ sum i)))
...    sum)
...

==> 10

; dotimes with result form
>>> (let ((total 0)) (dotimes (i 5 total) (setf total (+ total i))))
...

==> 10

; dotimes result form - var = count when evaluated
>>> (dotimes (i 5 i) nil)
...

==> 5

; dolist with early (return ...)
>>> (dolist (x '(1 2 3 4 5))
...    (if (= x 3) (return x)))
...

==> 3

; Error: stale return-from (no matching block active)
>>> (return-from nowhere 42)
%%% return-from: no block named NOWHERE is currently active.

; Error: stale return (no block nil active)
>>> (return 42)
%%% return-from: no block named NIL is currently active.

; Error: block name must be a symbol (not an integer)
>>> (block 42 1 2 3)
%%% Runtime Error: "" (1,2)
%%% (block 42 1 2 3)
%%%  ^
%%% block: name must be a symbol.

; Error: return-from name must be a symbol
>>> (return-from 42 99)
%%% Runtime Error: "" (1,2)
%%% (return-from 42 99)
%%%  ^
%%% return-from: name must be a symbol.

; ============================================================
; CATCH / THROW
; ============================================================

; --- catch and throw ---

; throw immediately returns value to catch; remaining body skipped
>>> (catch 'done (throw 'done 42) 99)
==> 42

; normal completion no throw; returns last body form
>>> (catch 'done 1 2 3)
==> 3

; empty body returns NIL
>>> (catch 'tag)
==> NIL

; throw crosses function-call boundary (dynamic extent)
>>> (defun thrower () (throw 'escape 99))
==> (FUNCTION THROWER () ...)

>>> (catch 'escape (thrower) 0)
==> 99

; nested catches: inner tag matches caught by inner; outer returns body after
>>> (catch 'outer
...    (catch 'inner
...       (throw 'inner 1))
...    2)
==> 2

; nested catches: outer tag propagates past inner, caught by outer
>>> (catch 'outer
...    (catch 'inner
...       (throw 'outer 99))
...    42)
==> 99

; tag is evaluated at runtime
>>> (let ((tag 'my-tag)) (catch tag (throw tag 77)))
==> 77

; numeric tag uses eql (same type, same value)
>>> (catch 1 (throw 1 "hit") "miss")
==> "hit"

; eql distinguishes numeric types mismatched tag is an unmatched throw
>>> (catch 1 (throw 1.0 "hit") "miss")
%%% throw: no catch for tag 1.0.

; throw with no matching catch error
>>> (throw 'nowhere 42)
%%% throw: no catch for tag NOWHERE.

; throw requires exactly 2 args
>>> (throw 'foo)
%%% Runtime Error: "" (1,2)
%%% (throw 'foo)
%%%  ^
%%% ERROR 'THROW': 1 argument provided; 2 expected.
%%% PRIMITIVE USAGE: (THROW tag result)

; ============================================================
; HANDLER-CASE
; ============================================================

; test33-conditions.log — Condition system: make-condition, signal, handler-case,
;                          ignore-errors, condition-type, condition-message

; make-condition — basic construction
>>> (make-condition 'my-error "something went wrong")
==> (DICT
   ("CONDITION-TYPE" MY-ERROR)
   ("MESSAGE" "something went wrong")
)

; conditionp — recognizes condition objects
>>> (conditionp (make-condition 'foo "bar"))
==> T

; conditionp — rejects non-conditions
>>> (conditionp "hello")
==> NIL

>>> (conditionp 42)
==> NIL

>>> (conditionp '(a b c))
==> NIL

; condition-type
>>> (condition-type (make-condition 'type-a "msg"))
==> TYPE-A

; condition-message
>>> (condition-message (make-condition 'type-a "the message"))
==> "the message"

; condition-message — empty message default
>>> (condition-message (make-condition 'type-a))
==> ""

; handler-case — catch by exact type
>>> (handler-case (signal 'my-error "oops")
...   (my-error (e) (condition-message e)))
==> "oops"

; handler-case — catch by T (catch-all)
>>> (handler-case (signal 'anything "caught")
...   (t (e) 'caught-it))
==> CAUGHT-IT

; handler-case — catch by ERROR (catch-all)
>>> (handler-case (signal 'whatever "msg")
...   (error (e) 'also-caught))
==> ALSO-CAUGHT

; handler-case — first matching clause wins
>>> (handler-case (signal 'file-error "not found")
...   (file-error (e) 'file-clause)
...   (t          (e) 'catchall-clause))
==> FILE-CLAUSE

; handler-case — non-matching type re-raises
>>> (handler-case (signal 'type-x "unhandled")
...   (type-y (e) 'wrong))
%%% Unhandled condition: (DICT
%%%    ("CONDITION-TYPE" TYPE-X)
%%%    ("MESSAGE" "unhandled")
%%% )

; handler-case — catches (error ...) primitive as ERROR condition
>>> (handler-case (error "something bad")
...   (error (e) (condition-message e)))
==> "something bad"

; handler-case — catches error primitive via T
>>> (handler-case (error "caught by t")
...   (t (e) 'got-it))
==> GOT-IT

; handler-case — normal execution (no signal) returns form value
>>> (handler-case (* 6 7)
...   (t (e) 'should-not-run))
==> 42

; handler-case — condition-type of a wrapped LRuntimeError is ERROR
>>> (handler-case (error "test")
...   (error (e) (condition-type e)))
==> ERROR

; handler-case — signal with condition object directly
>>> (let ((c (make-condition 'my-type "direct")))
...   (handler-case (signal c)
...     (my-type (e) (condition-message e))))
==> "direct"

; ignore-errors — suppresses errors, returns NIL
>>> (ignore-errors (error "swallowed"))
==> NIL

; ignore-errors — suppresses signaled conditions, returns NIL
>>> (ignore-errors (signal 'bad-thing "swallowed"))
==> NIL

; ignore-errors — returns normal value when no error
>>> (ignore-errors (* 3 4))
==> 12

; ignore-errors — returns last body form value
>>> (ignore-errors
...   (setf _ign_test_ 1)
...   (* 5 5))
==> 25

; handler-case — no var binding when var list is empty
>>> (handler-case (signal 'oops "ignored")
...   (oops () 'no-var-needed))
==> NO-VAR-NEEDED

; nested handler-case — inner catches first
>>> (handler-case
...   (handler-case (signal 'inner-err "inner")
...     (inner-err (e) 'inner-caught))
...   (t (e) 'outer-caught))
==> INNER-CAUGHT

; nested handler-case — unmatched inner propagates to outer
>>> (handler-case
...   (handler-case (signal 'unmatched "bubbles")
...     (other-type (e) 'wrong))
...   (t (e) 'outer-caught))
==> OUTER-CAUGHT

; condition-type and condition-message error on non-condition
>>> (condition-type 42)
%%% Runtime Error: "" (1,2)
%%% (condition-type 42)
%%%  ^
%%% condition-type: argument must be a condition object.

>>> (condition-message "oops")
%%% Runtime Error: "" (1,2)
%%% (condition-message "oops")
%%%  ^
%%% condition-message: argument must be a condition object.

; signal error on non-symbol, non-condition first arg
>>> (signal 42)
%%% Runtime Error: "" (1,2)
%%% (signal 42)
%%%  ^
%%% signal: first argument must be a condition object or a symbol.

; ============================================================
; MULTIPLE-VALUE-BIND
; ============================================================

; multiple-value-bind — exact match
>>> (multiple-value-bind (q r) (values 7 3)
...   (list q r))
==> (7 3)

; multiple-value-bind — fewer values than vars: extras get NIL
>>> (multiple-value-bind (a b c) (values 10 20)
...   (list a b c))
==> (10 20 NIL)

; multiple-value-bind — more values than vars: extras discarded
>>> (multiple-value-bind (x) (values 1 2 3)
...   x)
==> 1

; multiple-value-bind — single non-multiple value
>>> (multiple-value-bind (p q) 99
...   (list p q))
==> (99 NIL)

; multiple-value-bind — zero values: all vars get NIL
>>> (multiple-value-bind (a b) (values)
...   (list a b))
==> (NIL NIL)

; multiple-value-bind — body with multiple forms
>>> (multiple-value-bind (x y) (values 3 4)
...   (setf _mv_sum_ (+ x y))
...   (* x y))
==> 12

; ============================================================
; NTH-VALUE
; ============================================================

; nth-value — 0th value
>>> (nth-value 0 (values 'a 'b 'c))
==> A

; nth-value — 1st value
>>> (nth-value 1 (values 'a 'b 'c))
==> B

; nth-value — 2nd value
>>> (nth-value 2 (values 'a 'b 'c))
==> C

; nth-value — out of range returns NIL
>>> (nth-value 5 (values 1 2))
==> NIL

; nth-value — single non-multiple value: 0 returns it
>>> (nth-value 0 42)
==> 42

; nth-value — single non-multiple value: >0 returns NIL
>>> (nth-value 1 42)
==> NIL

; ============================================================
; MULTIPLE-VALUE-LIST
; ============================================================

; multiple-value-list — multiple values to list
>>> (multiple-value-list (values 1 2 3))
==> (1 2 3)

; multiple-value-list — single value to one-element list
>>> (multiple-value-list 42)
==> (42)

; multiple-value-list — zero values to empty list
>>> (multiple-value-list (values))
==> NIL
; --- scalar and tail contexts ---

; scalar context: multiple values stripped to primary in IF condition
>>> (if (values t nil) 'yes 'no)
==> YES

; scalar context: multiple values stripped in LET binding
>>> (let ((x (values 100 200)))
...   x)
==> 100

; scalar context: multiple values stripped in LET* binding
>>> (let* ((x (values 5 6))
...        (y (* x 2)))
...   y)
==> 10

; scalar context: multiple values stripped in SETQ
>>> (setq _mv_test_ (values 'first 'second))
==> FIRST

; scalar context: multiple values stripped as function arg
>>> (+ (values 3 99) (values 4 99))
==> 7

; tail position: multiple values propagate through progn
>>> (progn (values 1 2))
==> 1
2

; tail position: multiple values propagate through cond
>>> (cond (t (values 'x 'y)))
==> X
Y

; tail position: multiple values propagate through let body
>>> (let ((z 0))
...   (values z (+ z 1)))
==> 0
1

; values works in functions
>>> (defun quot-rem (n d)
...   (values (floor n d) (mod n d)))
==> (FUNCTION QUOT-REM (N D) ...)

>>> (multiple-value-bind (q r) (quot-rem 17 5)
...   (list q r))
==> (3 2)

>>> (nth-value 0 (quot-rem 17 5))
==> 3

>>> (nth-value 1 (quot-rem 17 5))
==> 2

; ============================================================
; MAKE-DICT
; ============================================================

; empty dict
>>> (make-dict)
==> (DICT
)

; two entries (values evaluated)
>>> (make-dict (a 1) (b 2))
==> (DICT
   (A 1)
   (B 2)
)

; computed value
>>> (make-dict (x (+ 1 2)))
==> (DICT
   (X 3)
)

; ============================================================
; : (MODULE ACCESS)
; ============================================================

; create a module
>>> (make-module 'somod)
==> #<MODULE SOMOD>

; set a field
>>> (module-set! somod 'a 42)
==> 42

; : operator
>>> (: somod a)
==> 42

; colon-reader shorthand
>>> somod:a
==> 42

; ============================================================
; CALL/CC
; ============================================================

; Basic escape: continuation invoked immediately
>>> (call/cc (lambda (k) (k 42)))
==> 42

; Lambda returns normally without invoking the continuation
>>> (call/cc (lambda (k) 99))
==> 99

; Continuation invoked inside nested arithmetic outer + still uses escaped value
>>> (+ 1 (call/cc (lambda (k) (+ 10 (k 42)))))
==> 43

; type-of a continuation is CONTINUATION
>>> (call/cc (lambda (k) (type-of k)))
==> CONTINUATION

; functionp is NIL for continuations
>>> (call/cc (lambda (k) (functionp k)))
==> NIL

; macrop is NIL for continuations
>>> (call/cc (lambda (k) (macrop k)))
==> NIL

>>> (call/cc (lambda (k) (k 99)))
==> 99

; Inner call/cc escape stays within the inner scope; outer computation proceeds normally
>>> (call/cc (lambda (k1) (+ 100 (call/cc (lambda (k2) (k2 5))))))
==> 105

; Inner call/cc escapes to the outer call/cc, bypassing the (+ 100 ...) entirely
>>> (+ 1000 (call/cc (lambda (k1) (+ 100 (call/cc (lambda (k2) (k1 5)))))))
==> 1005

; Early exit from dolist loop using call/cc
>>> (defun find-first (pred lst)
...    (call/cc (lambda (exit)
...                (dolist (x lst)
...                   (if (pred x) (exit x) nil))
...                nil)))
==> (FUNCTION FIND-FIRST (PRED LST) ...)

>>> (find-first evenp '(1 3 5 4 7))
==> 4

>>> (find-first evenp '(1 3 5 7))
==> NIL

; Continuation object pretty-prints as #<CONTINUATION>
>>> (string (call/cc (lambda (k) k)))
==> "#<CONTINUATION>"

; Re-invocable continuation: counter via call/cc
; k captures the state at the call/cc point (n=0); each (k nil) restores that
; state and re-runs the body.  When n reaches 4 the if falls through to n.
>>> (let ((n 0) (k nil))
...    (call/cc (lambda (c) (setq k c)))
...    (setq n (+ n 1))
...    (if (< n 4) (k nil) n))
==> 4

; call/cc requires exactly 1 argument
>>> (call/cc)
%%% Runtime Error: "" (1,2)
%%% (call/cc)
%%%  ^
%%% ERROR 'CALL/CC': 0 arguments provided; 1 expected.
%%% PRIMITIVE USAGE: (CALL/CC procedure)

; call/cc argument must be a callable
>>> (call/cc 42)
%%% ERROR 'CALL/CC': Argument must be a callable.
%%% PRIMITIVE USAGE: (CALL/CC procedure)

; call/cc argument may not be a special form pass quote (unquoted) to get the primitive
>>> (call/cc quote)
%%% ERROR 'CALL/CC': Argument may not be a special form.
%%% PRIMITIVE USAGE: (CALL/CC procedure)

; Continuation requires exactly 1 argument
>>> (call/cc (lambda (k) (k 1 2)))
%%% Runtime Error: "" (1,23)
