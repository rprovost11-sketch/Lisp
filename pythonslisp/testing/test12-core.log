; ============================================================
; Multiple values: values, multiple-value-bind, nth-value,
; values-list, multiple-value-list
; ============================================================


; Basic values - single value passes through unchanged
>>> (values 42)
==> 42

; Two values displayed one per line
>>> (values 1 2)
==> 1
2

; Three values
>>> (values 'a 'b 'c)
==> A
B
C

; Zero values
>>> (values)
==>


; values-list - converts list to multiple values
>>> (multiple-value-bind (a b c) (values-list '(10 20 30))
...   (+ a b c))
==> 60

; values-list - single element
>>> (values-list '(99))
==> 99


; floor, ceiling, round, truncate - multiple-value returns

; floor 1-arg: quotient and remainder
>>> (floor 7)
==> 7
0

>>> (floor -7)
==> -7
0

>>> (floor 7.5)
==> 7
0.5

>>> (floor -7.5)
==> -8
0.5

; floor 2-arg
>>> (multiple-value-bind (q r) (floor 17 5)
...   (list q r))
==> (3 2)

>>> (multiple-value-bind (q r) (floor -17 5)
...   (list q r))
==> (-4 3)

; floor scalar context - primary value only
>>> (+ (floor 7.9) 1)
==> 8

; ceiling 1-arg
>>> (ceiling 7.2)
==> 8
-0.7999999999999998

>>> (ceiling -7.2)
==> -7
-0.20000000000000018

; ceiling 2-arg
>>> (multiple-value-bind (q r) (ceiling 17 5)
...   (list q r))
==> (4 -3)

; round 1-arg (ties to even)
>>> (round 2.5)
==> 2
0.5

